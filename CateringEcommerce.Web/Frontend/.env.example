# API Configuration
VITE_API_BASE_URL=https://localhost:44368
VITE_UPLOAD_BASE_URL=https://localhost:44368/uploads

# Third-party Services
VITE_GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY
VITE_RAZORPAY_KEY_ID=YOUR_RAZORPAY_KEY_ID

# File Upload Configuration
VITE_MAX_FILE_SIZE=5242880                    # 5MB in bytes
VITE_ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/jpg
VITE_ALLOWED_VIDEO_TYPES=video/mp4,video/webm,video/quicktime

# OTP Configuration
VITE_OTP_EXPIRY_SECONDS=300                   # 5 minutes
VITE_OTP_MAX_ATTEMPTS=3

# GPS Configuration
VITE_GPS_TIMEOUT=10000                        # 10 seconds
VITE_GPS_MAX_AGE=60000                        # 1 minute
