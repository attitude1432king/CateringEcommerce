    "FileUpload": {
      "PermitLimit": 10,
      "WindowMinutes": 10
    }
  },
  "FileUploadSettings": {
    "MaxFileSizeMB": 10,
    "AllowedImageExtensions": [ ".jpg", ".jpeg", ".png", ".gif", ".webp" ],
    "AllowedDocumentExtensions": [ ".pdf", ".doc", ".docx" ],
    "UploadPath": "C:\\Uploads\\CateringEcommerce"
  },
  "HangfireSettings": {
    "DashboardPath": "/hangfire",
    "EnableDashboard": true,
    "DashboardTitle": "Catering Ecommerce Jobs",
    "WorkerCount": 5,
    "Queues": [ "critical", "default", "low" ]
  },
  "RABBITMQ": {
    "ENABLED": false,
    "HOSTNAME": "localhost",
    "PORT": 5672,
    "USERNAME": "guest",
    "PASSWORD": "",
