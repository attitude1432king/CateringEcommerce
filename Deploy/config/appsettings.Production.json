{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "REPLACE_WITH_SECURE_CONNECTION_STRING"
  },
  "JwtSettings": {
    "SecretKey": "REPLACE_WITH_SECURE_JWT_SECRET",
    "Issuer": "https://api.enyvora.com",
    "Audience": "https://enyvora.com",
    "ExpirationMinutes": 10080,
    "RefreshTokenExpirationDays": 30
  },
  "EmailSettings": {
    "Provider": "SendGrid",
    "ApiKey": "REPLACE_WITH_SENDGRID_API_KEY",
    "SenderEmail": "noreply@enyvora.com",
    "SenderName": "Enyvora Catering",
    "EnableSsl": true,
    "Port": 587
  },
  "AwsSns": {
    "AccessKey": "REPLACE_WITH_AWS_SNS_ACCESS_KEY",
    "SecretKey": "REPLACE_WITH_AWS_SNS_SECRET_KEY",
    "Region": "ap-south-1",
    "SenderId": "ENYVORA"
  },
  "RazorpaySettings": {
    "KeyId": "REPLACE_WITH_RAZORPAY_KEY_ID",
    "KeySecret": "REPLACE_WITH_RAZORPAY_KEY_SECRET",
    "WebhookSecret": "REPLACE_WITH_RAZORPAY_WEBHOOK_SECRET"
  },
  "CorsSettings": {
    "AllowedOrigins": [
      "https://enyvora.com",
      "https://www.enyvora.com"
    ]
  },
  "RateLimiting": {
    "AdminLogin": {
      "PermitLimit": 3,
      "WindowMinutes": 15
    },
    "UserLogin": {
      "PermitLimit": 5,
      "WindowMinutes": 15
    },
    "OtpSend": {
      "PermitLimit": 3,
      "WindowMinutes": 60
    },
    "OtpVerify": {
      "PermitLimit": 5,
      "WindowMinutes": 15
    },
    "FileUpload": {
      "PermitLimit": 10,
      "WindowMinutes": 10
    }
  },
  "FileUploadSettings": {
    "MaxFileSizeMB": 10,
    "AllowedImageExtensions": [ ".jpg", ".jpeg", ".png", ".gif", ".webp" ],
    "AllowedDocumentExtensions": [ ".pdf", ".doc", ".docx" ],
    "UploadPath": "C:\\Uploads\\CateringEcommerce"
  },
  "HangfireSettings": {
    "DashboardPath": "/hangfire",
    "EnableDashboard": true,
    "DashboardTitle": "Catering Ecommerce Jobs",
    "WorkerCount": 5,
    "Queues": [ "critical", "default", "low" ]
  },
  "RabbitMQSettings": {
    "Enabled": false,
    "HostName": "localhost",
    "Port": 5672,
    "UserName": "guest",
    "Password": "guest",
    "VirtualHost": "/",
    "ExchangeName": "catering_events",
    "QueueName": "catering_notifications"
  },
  "ApplicationInsights": {
    "InstrumentationKey": "",
    "EnableAdaptiveSampling": true,
    "EnableDependencyTracking": true
  },
  "SecuritySettings": {
    "EncryptionKey": "REPLACE_WITH_ENCRYPTION_KEY",
    "EnableOtpVerification": true,
    "OtpExpirationMinutes": 10,
    "MaxOtpAttempts": 3,
    "AccountLockoutDurationMinutes": 30,
    "MaxFailedLoginAttempts": 5,
    "PasswordHashWorkFactor": 12,
    "Enable2FA": true,
    "EnableDeviceFingerprinting": true
  },
  "FeatureFlags": {
    "EnableGoogleOAuth": true,
    "EnableFacebookOAuth": true,
    "EnableWishlist": true,
    "EnableReviews": true,
    "EnableComplaints": true,
    "EnableSupervisorPortal": true,
    "EnableNotifications": true,
    "EnableSplitPayments": true
  },
  "CacheSettings": {
    "EnableDistributedCache": false,
    "RedisConnectionString": "",
    "DefaultExpirationMinutes": 60
  }
}
