    "AdminLogin": {
      "PermitLimit": 3,
      "WindowMinutes": 15
    },
    "UserLogin": {
      "PermitLimit": 5,
      "WindowMinutes": 15
    },
    "OtpSend": {
      "PermitLimit": 3,
      "WindowMinutes": 60
